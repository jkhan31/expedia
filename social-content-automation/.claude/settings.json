{
  "project_name": "Social Content Automation",
  "description": "Automated multi-platform social media carousel and copy generation system",
  "permissions": {
    "read": {
      "allowed_paths": [
        "config/",
        "scripts/",
        "templates/",
        "assets/",
        "README.md",
        "CLAUDE.md",
        "SETUP.md",
        "GETTING_STARTED.md"
      ]
    },
    "write": {
      "allowed_paths": [
        "scripts/",
        "config/projects/",
        "config/branding.yaml",
        "config/copy_templates.yaml"
      ]
    },
    "execute": {
      "python": {
        "allowed_patterns": [
          "python scripts/batch_generate.py",
          "python scripts/carousel_generator.py",
          "python scripts/copy_generator.py",
          "python scripts/format_converter.py",
          "pip install -r requirements.txt"
        ]
      },
      "bash": {
        "allowed_commands": [
          "mkdir",
          "cp",
          "ls",
          "find"
        ]
      }
    }
  },
  "environment": {
    "PYTHONPATH": "./scripts",
    "PROJECT_ROOT": "."
  },
  "hooks": {
    "pre_generation": "Validate project config before running batch_generate.py",
    "post_generation": "Notify user that outputs/ folder is ready"
  }
}
